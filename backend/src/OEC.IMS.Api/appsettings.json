{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../../../data/oec-ims.db"
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "Jwt": {
    "Issuer": "OEC-IMS",
    "Audience": "OEC-IMS-Client",
    "SigningKey": "CHANGE_ME_USE_USER_SECRETS_IN_DEVELOPMENT_32_CHARS_MIN",
    "ExpirationMinutes": 480
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://nmanasareddy-prog.github.io"
    ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
